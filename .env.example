PORT=3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Afriwork <no-reply@example.com>
ADMIN_EMAIL=team@example.com
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
# Optional. If blank, the app uses the first tab in the spreadsheet.
GOOGLE_SHEETS_SHEET_NAME=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json
# Alternative to key file:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Recommended on Vercel instead of GOOGLE_SERVICE_ACCOUNT_KEY_FILE:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional feature flags. On Vercel these default to false.
# ENABLE_LOCAL_FILE_STORAGE=false
# ENABLE_DOWNLOAD_LINKS=false
